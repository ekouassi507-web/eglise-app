generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String
  phone        String?
  role         String    @default("BG_LEADER")
  group        String?
  bg           Int?
  subgroup     String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activities   Activity[]
  reports     WeeklyReport[]
}

model Member {
  id           String    @id @default(uuid())
  name         String
  phone        String?
  group        String
  bg           Int
  subgroup     String?
  isActive     Boolean   @default(true)
  joinedAt     DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Activity {
  id            String    @id @default(uuid())
  weekStart     DateTime
  day           String
  type          String
  attendees     String    @default("[]")
  absentees     String    @default("[]")
  absenteeReasons String   @default("{}")
  listened      String    @default("[]")
  notes         String?
  createdById   String
  createdBy     User      @relation(fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model WeeklyReport {
  id              String    @id @default(uuid())
  bergerId        String
  berger          User      @relation(fields: [bergerId], references: [id])
  weekStart       DateTime
  weekEnd         DateTime
  
  personalLife    String?
  
  tuesdayMobilized      Boolean @default(false)
  tuesdayDesignated     String  @default("[]")
  tuesdayCount          Int     @default(0)
  
  wednesdayMobilized    Boolean @default(false)
  wednesdayFromTuesday  Boolean @default(false)
  wednesdayCount        Int     @default(0)
  
  fridayMobilized       Boolean @default(false)
  fridayAllMembers     Boolean @default(false)
  fridayCount           Int     @default(0)
  
  sundayMobilized       Boolean @default(false)
  sundayAllMembers     Boolean @default(false)
  sundayCount           Int     @default(0)
  sundayListened        Int     @default(0)
  
  monthlyActivities    String?
  prayerChains         String?
  qiQuotidien          Boolean @default(false)
  qiIntermittent       Boolean @default(false)
  bookToStudy          String?
  
  absencesNames     String  @default("[]")
  absencesReasons   String  @default("{}")
  
  supervisionTheme     String?
  visitedPersons       String  @default("[]")
  visitPurpose         String?
  visitDate            String?
  visitTime            String?
  
  otherObservations   String?
  
  signature        Boolean @default(false)
  signedAt         DateTime?
  status           String  @default("DRAFT")
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
